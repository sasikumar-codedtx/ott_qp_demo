CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/Firstlight/Frameworks" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Firstlight/FLAnalytics" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Firstlight/FLBookmarks" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Firstlight/FLContentAuthorizer" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Firstlight/FLFoundation" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Firstlight/FLHeartbeat" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Firstlight/FLPlatformCore" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Firstlight/FLPlatformPlayer" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Firstlight/FLPlayer" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Firstlight/FLPlayerInterface" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Firstlight/FLStreamConcurrency"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
LD_RUNPATH_SEARCH_PATHS = $(inherited) '@executable_path/Frameworks' '@loader_path/Frameworks'
OTHER_LDFLAGS = $(inherited) -framework "FLAnalytics" -framework "FLBookmarks" -framework "FLContentAuthorizer" -framework "FLFoundation" -framework "FLHeartbeat" -framework "FLPlatformCore" -framework "FLPlatformPlayer" -framework "FLPlayer" -framework "FLPlayerInterface" -framework "FLStreamConcurrency"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/Firstlight"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
